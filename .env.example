# Copy to .env — never commit .env

# === Annotation / database ===
TOSMOD_DB_PATH=./data/tosmod.db
ANONYMIZATION_SALT=generate_with_python_secrets_token_hex_32

# === Official connectors ===
YOUTUBE_API_KEY=
TIKTOK_RESEARCH_CLIENT_KEY=
TIKTOK_RESEARCH_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ToSMod/0.1 (research)

# === Opt-in collectors (see tosmod/connectors/opt_in/LEGAL.md) ===
TOSMOD_ENABLE_OPT_IN=0
APIFY_API_KEY=

# === Optional LLM silver-labeling ===
OLLAMA_BASE_URL=http://localhost:11434

# Legacy alias (still supported)
THESIS_DB_PATH=
